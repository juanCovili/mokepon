  <diagram id="class-003" name="Clases y lógica de combate">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title3" value="MOKEPON - Clase Mokepon y lógica de combate" style="text;html=1;align=center;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="220" y="20" width="660" height="40" as="geometry" />
        </mxCell>

        <mxCell id="classM" value="&lt;&lt;class&gt;&gt; Mokepon" style="swimlane;html=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="260" height="240" as="geometry" />
        </mxCell>
        <mxCell id="attrM" value="- nombre: string&#10;- foto: string&#10;- vida: number (5)&#10;- ataques: Array&lt;{nombre,id}&gt;&#10;- x, y: number (10,10)&#10;- ancho, alto: number (80)&#10;- velocidadX, velocidadY: number&#10;- mapaFoto: Image" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=none;strokeColor=none;" vertex="1" parent="classM">
          <mxGeometry x="10" y="40" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="methM" value="+ constructor(nombre,foto,vida,fotoMapa,x,y)&#10;+ pintarMokepon(): dibuja en canvas" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=none;strokeColor=none;separatorColor=#6c8ebf;" vertex="1" parent="classM">
          <mxGeometry x="10" y="170" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="inst" value="Instancias (mokepones):&#10;• hipodoge, capipepo, ratigueya (jugador)&#10;• hipodogeEnemigo, capipepoEnemigo, ratigueyaEnemigo&#10;&#10;Arrays globales:&#10;• mokepones[] = [hipodoge, capipepo, ratigueya]&#10;• ataqueJugador[], ataqueEnemigo[]&#10;• victoriasJugador, victoriasEnemigo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="420" y="80" width="300" height="160" as="geometry" />
        </mxCell>

        <mxCell id="triangle" value="TRIÁNGULO DE ELEMENTOS (combate)" style="text;html=1;align=center;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="120" y="370" width="360" height="30" as="geometry" />
        </mxCell>

        <mxCell id="fuego" value="FUEGO 🔥" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="420" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tierra" value="TIERRA 🌱" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="agua" value="AGUA 💦" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="520" width="120" height="60" as="geometry" />
        </mxCell>

        <mxCell id="t1" value="vence a" style="endArrow=classic;html=1;fontSize=10;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="fuego" target="tierra">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="vence a" style="endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="tierra" target="agua">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="vence a" style="endArrow=classic;html=1;fontSize=10;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="agua" target="fuego">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="logic" value="combate() por cada uno de los 5 ataques:&#10;• iguales  → EMPATE&#10;• FUEGO vs TIERRA → GANASTE (+1)&#10;• AGUA  vs FUEGO  → GANASTE (+1)&#10;• TIERRA vs AGUA  → GANASTE (+1)&#10;• otro caso        → PERDISTE (enemigo +1)&#10;&#10;revisarVidas(): mayor número de victorias gana." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="520" y="380" width="360" height="200" as="geometry" />
        </mxCell>

        <mxCell id="rel1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;dashed=1;" edge="1" parent="1" source="classM" target="inst">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
